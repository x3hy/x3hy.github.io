#!/usr/bin/bash
import json
from sys import argv

# Returns value of key=val argument
def process_arg_string(arg: str)->str:
    if not '=' in arg:
        return str(arg);

    return str (arg.split ('=')[1]);


if __name__ == "__main__":
    if len(argv) < 2:
        exit(0)

    # Process arguments
    for arg in argv:
        template=""
        data=""

        if arg == "-t":
            template = process_arg_string (arg)
        elif arg == "-d"
            data = process_arg_string (arg)
